{
  "root": "dist/",
  "clean_urls": false,
  "routes": {
    "/dashboard-index.html": "dashboard-index.html",
    "/**": "index.html"
  },
  "https_only": true,
  "headers": {
    "/**": {
      "Cache-Control": "public, max-age=0, must-revalidate"
    },
    "/assets/**": {
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  }
}
