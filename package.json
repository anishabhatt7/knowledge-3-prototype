{
  "name": "knowledge-builder-dvs-v2",
  "version": "1.0.0",
  "description": "DVS Knowledge Agent Dashboard — Review Article workspace (SLDS 2 + LWC). Clone of New-Knowledge-Authoring (Flow 3 / Knowledge 3.0).",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf dist .vite node_modules",
    "prebuild-icons": "node scripts/prebuild-icons.mjs",
    "dev": "node scripts/prebuild-icons.mjs && vite",
    "build": "node scripts/prebuild-icons.mjs && vite build",
    "build:gh-pages": "node scripts/prebuild-icons.mjs && vite build --mode gh-pages",
    "preview": "vite preview",
    "deploy": "npm run build:gh-pages && gh-pages -d dist --dest v1 --add --nojekyll -r https://github.com/anishabhatt7/knowledge-3-prototype.git",
    "dev:native-shadow": "echo 'To use native shadow, set disableSyntheticShadowSupport: true in vite.config.js'",
    "heroku-postbuild": "npm run build",
    "start": "serve -s dist -l $PORT"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@lwc/synthetic-shadow": "^9.0.2",
    "@salesforce-ux/design-system": "^2.29.0",
    "@salesforce-ux/design-system-2": "^0.0.0-alpha.0",
    "d3": "^7.9.0",
    "gsap": "^3.15.0",
    "lightning-base-components": "^1.28.15-alpha",
    "lwc": "^9.0.2",
    "motion": "^12.39.0",
    "serve": "^14.2.6",
    "vite": "^7.3.1",
    "vite-plugin-lwc": "^4.1.0"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
